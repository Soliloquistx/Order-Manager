function clearDateRange() {
  document.getElementById('dateFrom').value = '';
  document.getElementById('dateTo').value = '';
  updateDrpLabel();
  applyFilters();
  document.getElementById('drpDropdown').classList.remove('open');
}
function updateDrpLabel() {
  const from = document.getElementById('dateFrom').value;
  const to = document.getElementById('dateTo').value;
  const label = document.getElementById('drpLabel');
  if (from && to) label.textContent = `📅 ${from} ~ ${to}`;
  else if (from) label.textContent = `📅 ${from} ~`;
  else if (to) label.textContent = `📅 ~ ${to}`;
  else label.textContent = '📅 选择日期';
}
