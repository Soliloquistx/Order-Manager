  }
});

// ════════════════════════════════════════════
//  Column Settings
// ════════════════════════════════════════════
const colIndex = {
  order: 2, customer: 3, channel: 4, depart: 5,
  pid: 6, route: 7, owner: 8, butler: 9,
  status: 10, amount: 11,
  et818: 12,
};

function toggleColSettings() {
  document.getElementById('colSettings').classList.toggle('open');
}

function applyColSettings() {
  const checks = document.querySelectorAll('.cs-item input');
  // Map column to filter element
  const filterMap = {
    depart: 'dateRangeWrap',
    route: 'routeFilter',
    owner: 'ownerFilter',
    butler: 'butlerFilter',
    status: 'statusFilter',
    et818: 'et818StatusFilter',
  };
  checks.forEach(cb => {
    const col = cb.closest('.cs-item').dataset.col;
    const visible = cb.checked;
    const idx = colIndex[col];
    if (idx) {
      // Hide th by nth-child
      document.querySelectorAll('.wt th:nth-child(' + idx + ')').forEach(el => {
        el.style.display = visible ? '' : 'none';
      });
      // Hide td by nth-child in each row
      document.querySelectorAll('.wt tbody tr').forEach(tr => {
        const td = tr.querySelector('td:nth-child(' + idx + ')');
        if (td) td.style.display = visible ? '' : 'none';
      });
    }
    // Hide corresponding filter (hide parent .filter div)
    const filterId = filterMap[col];
    if (filterId) {
      const filterEl = document.getElementById(filterId);
      if (filterEl) {
        const parent = filterEl.closest('.filter') || filterEl;
        parent.style.display = visible ? '' : 'none';
      }
    }
  });
  // Save to localStorage
  const state = {};
  checks.forEach(cb => { state[cb.closest('.cs-item').dataset.col] = cb.checked; });
  localStorage.setItem('order_col_visibility', JSON.stringify(state));
}

// Restore column settings from localStorage
function restoreColSettings() {
  try {
    const saved = JSON.parse(localStorage.getItem('order_col_visibility'));
    if (!saved) return;
    document.querySelectorAll('.cs-item input').forEach(cb => {
      const col = cb.closest('.cs-item').dataset.col;
      if (saved[col] !== undefined) cb.checked = saved[col];
    });
    applyColSettings();
  } catch(e) {}
}

// Close col settings on outside click
document.addEventListener('click', e => {
  if (!e.target.closest('.col-settings') && !e.target.closest('.settings-btn')) {
    document.getElementById('colSettings').classList.remove('open');
  }
});

// ════════════════════════════════════════════
//  Column Resize
// ════════════════════════════════════════════
const colKeys = ['cb','order','customer','channel','depart','pid','route','owner','butler','status','amount','et818','actions'];

function initColResize() {
  document.querySelectorAll('.wt').forEach(table => {
    const headers = table.querySelectorAll('thead th');
    headers.forEach((th, i) => {
      const key = colKeys[i];
      if (!key || key === 'actions') return; // skip actions column
      // Wrap content if not already wrapped
      if (th.querySelector('.th-wrap')) return;
      const wrap = document.createElement('span');
      wrap.className = 'th-wrap';
      while (th.firstChild) wrap.appendChild(th.firstChild);
      th.appendChild(wrap);
      // Add resize handle
      const handle = document.createElement('span');
      handle.className = 'resize-handle';
      handle.dataset.col = key;
      th.appendChild(handle);
      handle.addEventListener('mousedown', onResizeStart);
    });
  });
  // Restore saved widths
  try {
    const saved = JSON.parse(localStorage.getItem('order_col_widths'));
    if (saved) {
      Object.entries(saved).forEach(([key, w]) => {
        document.querySelectorAll(`.resize-handle[data-col="${key}"]`).forEach(h => {
          const th = h.parentElement;
          // Set width on both th and corresponding col if exists
          th.style.width = w + 'px';
          const idx = colKeys.indexOf(key);
          if (idx > 0) {
            const table = th.closest('.wt');
            // Apply to all rows' td:nth-child
            table.querySelectorAll('tbody tr').forEach(tr => {
              const td = tr.querySelector('td:nth-child(' + idx + ')');
              if (td) td.style.width = w + 'px';
            });
          }
        });
      });
    }
  } catch(e) {}
}

let resizeCol = null;

function onResizeStart(e) {
  const handle = e.currentTarget;
  const th = handle.parentElement;
  const table = th.closest('.wt');
  const idx = Array.from(table.querySelectorAll('thead th')).indexOf(th) + 1;
  resizeCol = { th, table, idx, startX: e.clientX, startW: th.offsetWidth, handle };
  handle.classList.add('active');
  document.body.style.cursor = 'col-resize';
  document.body.style.userSelect = 'none';
  document.addEventListener('mousemove', onResizeMove);
  document.addEventListener('mouseup', onResizeEnd);
  e.preventDefault();
}

function onResizeMove(e) {
  if (!resizeCol) return;
  const diff = e.clientX - resizeCol.startX;
  let w = Math.max(40, resizeCol.startW + diff);
  const idx = resizeCol.idx;
  // Apply to ALL tables, not just the current one
  document.querySelectorAll('.wt').forEach(table => {
    const th = table.querySelector('thead th:nth-child(' + idx + ')');
    if (th) th.style.width = w + 'px';
    table.querySelectorAll('tbody tr').forEach(tr => {
      const td = tr.querySelector('td:nth-child(' + idx + ')');
      if (td) td.style.width = w + 'px';
    });
  });
}

function onResizeEnd() {
  if (!resizeCol) return;
  resizeCol.handle.classList.remove('active');
  document.body.style.cursor = '';
  document.body.style.userSelect = '';
  document.removeEventListener('mousemove', onResizeMove);
  document.removeEventListener('mouseup', onResizeEnd);
  // Save width
  const key = colKeys[resizeCol.idx - 1];
  if (key) {
    try {
      const saved = JSON.parse(localStorage.getItem('order_col_widths') || '{}');
      saved[key] = resizeCol.th.offsetWidth;
      localStorage.setItem('order_col_widths', JSON.stringify(saved));
    } catch(e) {}
  }
  resizeCol = null;
}

function applyFilters() {
  const search = (document.getElementById('searchBox').value || '').trim().toLowerCase();
  const dateFrom = document.getElementById('dateFrom').value;
  const dateTo = document.getElementById('dateTo').value;
  const owner = document.getElementById('ownerFilter').value;
  const butler = document.getElementById('butlerFilter').value;
  const route = document.getElementById('routeFilter').value;
  const status = document.getElementById('statusFilter').value;
  const paymentValues = getPaymentFilterValues();
  const et818Filter = document.getElementById('et818StatusFilter').value;

  let filtered = MOCK_ORDERS.filter(o => {
    if (search) {
      const haystack = [o.order_no, o.customer_name, o.customer_phone, o.product_name, o.channel].join(' ').toLowerCase();
      if (!haystack.includes(search)) return false;
    }
    if (dateFrom && o.departure_date < dateFrom) return false;
    if (dateTo && o.departure_date > dateTo) return false;
    if (owner && (o.owner || '') !== owner) return false;
    if (butler && (o.butler || '') !== butler) return false;
    if (route && o.product_name !== route) return false;
    if (status && o.order_status !== status) return false;
    if (paymentValues.length && !paymentValues.includes(o.payment_status)) return false;
    if (et818Filter && (o.et818_status || '') !== et818Filter) return false;
    return true;
  });

  orders = filtered;
  syncFiltersToUrl();
  render();
}

function clearFilters() {
  document.getElementById('searchBox').value = '';
  document.getElementById('dateFrom').value = '';
  document.getElementById('dateTo').value = '';
  document.getElementById('ownerFilter').value = '';
  document.getElementById('butlerFilter').value = '';
  document.getElementById('routeFilter').value = '';
  document.getElementById('statusFilter').value = '';
  document.getElementById('et818StatusFilter').value = '';
  // Reset multi-select payment
  document.querySelectorAll('#paymentDropdown input[type="checkbox"]').forEach(cb => cb.checked = cb.value === '');
  updatePaymentLabel();
  orders = [...MOCK_ORDERS];
  syncFiltersToUrl();
  render();
}

// ════════════════════════════════════════════
//  Multi-select (支付情况)
// ════════════════════════════════════════════
let msOpen = null;

function toggleMs(name) {
  const dd = document.getElementById(name + 'Dropdown');
  if (msOpen && msOpen !== name) {
    document.getElementById(msOpen + 'Dropdown').classList.remove('open');
  }
  dd.classList.toggle('open');
  msOpen = dd.classList.contains('open') ? name : null;
}

function toggleMsAll(name) {
  const allCb = document.querySelector(`#${name}Dropdown input[value=""]`);
  const checked = allCb.checked;
  document.querySelectorAll(`#${name}Dropdown input[type="checkbox"]`).forEach(cb => {
    cb.checked = checked;
  });
  updatePaymentLabel();
  applyFilters();
}

function applyMsFilter(name) {
  const allCb = document.querySelector(`#${name}Dropdown input[value=""]`);
  const others = document.querySelectorAll(`#${name}Dropdown input:not([value=""])`);
  const allChecked = Array.from(others).every(cb => cb.checked);
  allCb.checked = allChecked;
  updatePaymentLabel();
  applyFilters();
}

function updatePaymentLabel() {
  const checked = document.querySelectorAll('#paymentDropdown input:not([value=""]):checked');
  const label = document.getElementById('paymentLabel');
  if (checked.length === 0 || document.querySelector('#paymentDropdown input[value=""]:checked')) {
    label.textContent = '支付情况';
  } else {
    label.textContent = Array.from(checked).map(cb => cb.value).join(', ');
  }
}

function getPaymentFilterValues() {
  if (document.querySelector('#paymentDropdown input[value=""]:checked')) return [];
  return Array.from(document.querySelectorAll('#paymentDropdown input:not([value=""]):checked')).map(cb => cb.value);
}

// Close multi-select on outside click
document.addEventListener('click', e => {
  if (msOpen && !e.target.closest('.multi-select')) {
    document.getElementById(msOpen + 'Dropdown').classList.remove('open');
    msOpen = null;
  }
});

// ════════════════════════════════════════════
//  Context Menu (右键菜单)
// ════════════════════════════════════════════
let cmOrder = null;

function cmShow(e, orderId) {
  e.preventDefault();
  cmOrder = MOCK_ORDERS.find(o => o.id === orderId) || orders.find(o => o.id === orderId);
  const menu = document.getElementById('contextMenu');
  let x = e.clientX, y = e.clientY;
  const mw = 200, mh = menu.scrollHeight || 240;
  if (x + mw > window.innerWidth) x = window.innerWidth - mw - 8;
  if (y + mh > window.innerHeight) y = window.innerHeight - mh - 8;
  menu.style.left = x + 'px';
  menu.style.top = y + 'px';
  menu.classList.add('open');
  return false;
}

function cmHide() {
  document.getElementById('contextMenu').classList.remove('open');
  cmOrder = null;
}

function cmCopy(mode) {
  if (!cmOrder) return;
  let text = '';
  switch (mode) {
    case 'id': text = cmOrder.order_no; break;
    case 'customer': text = cmOrder.customer_name; break;
    case 'route': text = cmOrder.product_name; break;
    case 'id_customer_route': text = `${cmOrder.order_no}\t${cmOrder.customer_name}\t${cmOrder.product_name}`; break;
  }
  navigator.clipboard.writeText(text).then(() => { cmHide(); }).catch(() => { cmHide(); });
}

function cmCompare() {
  if (!cmOrder) return;
  const id = cmOrder.id; cmHide();
  window.open(`/compare/${id}`, '_blank');
}

function cmOpenVbk() {
  if (!cmOrder) return; cmHide();
  window.open(`https://vbooking.ctrip.com/order/orderDetail?orderId=${cmOrder.order_no}`, '_blank');
}

function cmOpenEt() {
  if (!cmOrder) return;
  const orderNo = cmOrder.order_no; cmHide();
  fetch('/api/et818/find-by-order-no', {
    method: 'POST', headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({ order_no: orderNo })
  })
  .then(r => r.json())
  .then(data => {
    if (data.ok && data.matches && data.matches.length) {
      window.open(data.matches[0].detail_url, '_blank');
    } else { alert('未在 ET818 中找到该订单号'); }
  })
  .catch(() => alert('查询 ET818 失败'));
}

function cmRefresh() {
  if (!cmOrder) return;
  const orderId = cmOrder.id;
  const orderNo = cmOrder.order_no;
  cmHide();
  // Show status feedback
  const status = document.getElementById('lookupStatus');
  status.className = 'lookup-status';
  status.textContent = `正在刷新订单 ${orderNo}...`;
  fetch(`/api/orders/${orderId}/sync-vbk-detail-from-browser`, {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({ order_no: orderNo, list_kind: 'auto', sync_if_missing: true })
  })
  .then(r => r.json())
  .then(data => {
    if (data.ok) {
      status.className = 'lookup-status ok';
      status.textContent = `订单 ${orderNo} 已刷新`;
      // TODO: reload from API when real data is connected
      setTimeout(() => { status.className = 'lookup-status'; status.textContent = ''; }, 3000);
    } else {
      status.className = 'lookup-status err';
      status.textContent = data.detail || '刷新失败';
    }
  })
  .catch(err => {
    status.className = 'lookup-status err';
    status.textContent = '刷新失败: ' + err.message;
  });
}

// Close context menu on outside click or Escape
document.addEventListener('click', e => { if (!e.target.closest('.cm')) cmHide(); });
document.addEventListener('keydown', e => { if (e.key === 'Escape') cmHide(); });

// ════════════════════════════════════════════
//  Refresh All
// ════════════════════════════════════════════
function refreshAllOrders() {
  const btn = document.getElementById('refreshAllBtn');
  if (btn.disabled) return;
  const list = orders;
  if (!list.length) { alert('没有可刷新的订单'); return; }

  btn.disabled = true;
  btn.textContent = `🔄 刷新中 0/${list.length}`;

  let done = 0, failed = 0;
  const status = document.getElementById('lookupStatus');

  function next(i) {
    if (i >= list.length) {
      btn.disabled = false;
      const msg = failed ? `全部刷新完成，成功 ${done}，失败 ${failed}` : `全部刷新完成，共 ${done} 单`;
      btn.textContent = '🔄 全部刷新';
      status.className = failed ? 'lookup-status err' : 'lookup-status ok';
      status.textContent = msg;
      setTimeout(() => { status.className = 'lookup-status'; status.textContent = ''; }, 5000);
      return;
    }
    const o = list[i];
    btn.textContent = `🔄 刷新中 ${i+1}/${list.length}`;
    fetch(`/api/orders/${o.id}/sync-vbk-detail-from-browser`, {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({ order_no: o.order_no, list_kind: 'auto', sync_if_missing: true })
    })
    .then(r => r.json())
    .then(data => {
      if (data.ok) done++; else failed++;
      next(i + 1);
    })
    .catch(() => { failed++; next(i + 1); });
  }
  next(0);
}

// ════════════════════════════════════════════
//  Render
// ════════════════════════════════════════════
function render() {
  const container = document.getElementById('tableContainer');

  // Stats
  updateStats();

  // Group by selected field
  const groups = {};
  const groupLabelMap = {
    departure_date: '出发日期',
    order_date: '下单日期',
    product_name: '路线',
    owner: '负责人',
    butler: '管家',
  };
  orders.forEach(o => {
    let key = o[groupField] || '未设置';
    if (groupField === 'owner' || groupField === 'butler') {
      key = o[groupField] || '未设置';
    }
    if (!groups[key]) groups[key] = [];
    groups[key].push(o);
  });
  // Sort keys: dates sort chronologically, others alphabetically
  const isDateField = groupField === 'departure_date' || groupField === 'order_date';
  const sortedKeys = Object.keys(groups).sort((a, b) => {
    if (a === '未设置') return 1;
    if (b === '未设置') return -1;
    if (isDateField) return a.localeCompare(b);
    return a.localeCompare(b, 'zh');
  });

  // Check empty
  if (!sortedKeys.length) {
    container.innerHTML = `
      <div class="empty-state">
        <div class="icon">📭</div>
        <div class="title">当前筛选结果为空</div>
        <div class="desc">试试修改搜索词或清除筛选条件</div>
      </div>`;
    document.getElementById('totalCount').textContent = '0';
    return;
  }

  document.getElementById('totalCount').textContent = orders.length;

  let html = '';

  if (groupField === 'none') {
    // Flat list — no groups
    const totalAmount = orders.reduce((s, o) => {
      if (o.payment_status === '已支付') return s + (o.total_amount || 0);
      if (o.payment_status === '部分支付') return s + (o.paid_amount || 0);
      return s;
    }, 0);
    html = `
      <div class="group">
        <div class="group-body" style="display:block">
          <table class="wt flat">
            <thead>
              <tr>
                <th class="cb"><input type="checkbox" id="checkAllFlat" onchange="document.querySelectorAll('.row-cb').forEach(c=>c.checked=this.checked)" /></th>
                <th class="col-order">订单号</th>
                <th class="col-customer">客户</th>
                <th class="col-channel">渠道</th>
                <th class="col-depart">出发日期<br/>下单日期</th>
                <th class="col-pid">ID</th>
                <th style="width:20%">线路</th>
                <th class="col-owner">负责人</th>
                <th class="col-butler">管家</th>
                <th class="col-status">状态</th>
                <th class="col-amount">金额</th>
                <th class="col-et818">ET818</th>
                <th class="col-actions">操作</th>
              </tr>
            </thead>
            <tbody>
              ${orders.map(o => renderRow(o)).join('')}
            </tbody>
          </table>
        </div>
      </div>`;
  } else {
    // Grouped by field
    sortedKeys.forEach((key, gi) => {
    const items = groups[key];
    const groupTotal = items.reduce((s, o) => {
      if (o.payment_status === '已支付') return s + (o.total_amount || 0);
      if (o.payment_status === '部分支付') return s + (o.paid_amount || 0);
      return s;
    }, 0);
    // Consistent color by key hash (same key = same color across renders)
    const colorIdx = hashStr(key) % 10;

    html += `
      <div class="group">
        <div class="gh gh-${colorIdx}" onclick="toggleGroup(this)">
          <span class="arrow open">▶</span>
          <span class="date">${esc(key)}</span>
          <span class="count">${items.length}单</span>
          <span class="et-progress">${renderGroupEtProgress(items)}</span>
          <span class="group-stats">
            <span class="gs-item">💰 ${fmtMoney(groupTotal)}</span>
          </span>
          <span class="group-total" style="display:none"></span>
        </div>
        <div class="group-body" style="display:block">
          <table class="wt">
            <thead>
              <tr>
                <th class="cb"><input type="checkbox" onchange="toggleAll(this,'${key}')" /></th>
                <th class="col-order">订单号</th>
                <th class="col-customer">客户</th>
                <th class="col-channel">渠道</th>
                <th class="col-depart">出发日期<br/>下单日期</th>
                <th class="col-pid">ID</th>
                <th style="width:20%">线路</th>
                <th class="col-owner">负责人</th>
                <th class="col-butler">管家</th>
                <th class="col-status">状态</th>
                <th class="col-amount">金额</th>
                <th class="col-et818">ET818</th>
                <th class="col-actions">操作</th>
              </tr>
            </thead>
            <tbody>
              ${items.map(o => renderRow(o)).join('')}
            </tbody>
          </table>
        </div>
      </div>`;
  });  // end forEach
  }  // end else (grouped)

  container.innerHTML = html;
  restoreColSettings();
  initColResize();
}

function changeGroupBy(value) {
  groupField = value;
  syncFiltersToUrl();
  render();
}

function renderRow(o) {
  const statusBadge = statusLabel(o.order_status);
  const paymentBadge = paymentLabel(o.payment_status);

  const isCancelled = o.payment_status === '已退款' || o.payment_status === '取消支付' || o.order_status === '已取消' || o.order_status === '已关闭';
  const rowClass = isCancelled ? 'cancelled' : '';

  return `
    <tr data-id="${o.id}" class="${rowClass}" oncontextmenu="return cmShow(event, ${o.id})">
      <td class="cb"><input type="checkbox" class="row-cb" /></td>
      <td class="mono">${o.order_no}</td>
      <td>
        <div class="customer">${esc(o.customer_name)}
          <span class="phone">${esc(o.customer_phone || '')}</span>
        </div>
      </td>
      <td><span class="badge ${channelBadgeCls(o.channel)}"><span class="dot"></span>${esc(o.channel)}</span></td>
      <td class="mono" style="font-size:12px;line-height:1.6">
        <div>${o.departure_date}</div>
        <div style="color:var(--tm);font-size:11px">${o.order_date || '—'}</div>
      </td>
      <td><a class="pid-link" href="https://vacations.ctrip.com/travel/detail/p${o.product_id}.html" target="_blank" title="打开携程产品页">${o.product_id || '—'}</a></td>
      <td style="font-size:12px;color:var(--ts);max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="${esc(o.product_name)}">${esc(o.product_name)}</td>
      <td><span class="editable-text" onclick="editField(this,${o.id},'owner')">${o.owner ? esc(o.owner) : '<span class="placeholder">—</span>'}</span></td>
      <td><span class="editable-text" onclick="editField(this,${o.id},'butler')">${o.butler ? esc(o.butler) : '<span class="placeholder">—</span>'}</span></td>
      <td>
        <span class="badge ${paymentBadge.cls}"><span class="dot"></span>${paymentBadge.label}</span>
        <span class="badge ${statusBadge.cls}" style="margin-left:4px"><span class="dot"></span>${statusBadge.label}</span>
      </td>
      <td><span class="amount ${o.payment_status === '已支付' ? 'paid' : 'unpaid'}">${fmtMoney(o.payment_status === '部分支付' ? (o.paid_amount || 0) : o.total_amount)}</span></td>
      <td><span class="badge ${et818BadgeCls(o.et818_status || '')}">${esc(o.et818_status || '—')}</span></td>
      <td>
        <div class="actions">
          <a class="link" href="/compare/${o.id}" target="_blank" title="双栏对比">详情</a>
          <span class="link note" onclick="editNote(this,${o.id})" title="备注">${o.et_note ? esc(o.et_note) : '备注'}</span>
        </div>
      </td>
    </tr>`;
}

// ════════════════════════════════════════════
//  Group toggle
// ════════════════════════════════════════════
function toggleGroup(el) {
  const body = el.nextElementSibling;
  const arrow = el.querySelector('.arrow');
  if (body.style.display === 'none') {
    body.style.display = 'block';
    arrow.classList.add('open');
  } else {
    body.style.display = 'none';
    arrow.classList.remove('open');
  }
}

// ════════════════════════════════════════════
//  Stats
// ════════════════════════════════════════════
function updateStats() {
  const total = orders.length;
  const paid = orders.filter(o => o.payment_status === '已支付').length;
  const partial = orders.filter(o => o.payment_status === '部分支付').length;
  const unpaid = orders.filter(o => o.payment_status === '未支付').length;
  const confirmed = orders.filter(o => o.order_status === '已确认').length;
  const pending = orders.filter(o => o.order_status === '待确认').length;
  const totalAmount = orders.reduce((s, o) => {
    if (o.payment_status === '已支付') return s + (o.total_amount || 0);
    if (o.payment_status === '部分支付') return s + (o.paid_amount || 0);
    return s;
  }, 0);

  document.getElementById('statTotal').textContent = total;
  document.getElementById('statPaid').textContent = paid;
  document.getElementById('statPartial').textContent = partial;
  document.getElementById('statUnpaid').textContent = unpaid;
  document.getElementById('statConfirmed').textContent = confirmed;
  document.getElementById('statPending').textContent = pending;
  const etDone = orders.filter(o => o.et818_status === '已提交' || o.et818_status === '已填写').length;
  document.getElementById('statEtDone').textContent = `${etDone}/${total}`;
  document.getElementById('statAmount').textContent = fmtMoney(totalAmount);
}

// ════════════════════════════════════════════
//  Helpers
// ════════════════════════════════════════════
function statusLabel(s) {
  if (s === '已确认') return { label: '已确认', cls: 'badge-blue' };
  if (s === '待确认') return { label: '待确认', cls: 'badge-amber' };
  if (s === '已出行') return { label: '已出行', cls: 'badge-green' };
  if (s === '已完成') return { label: '已完成', cls: 'badge-green' };
  if (s === '已取消' || s === '已关闭') return { label: s, cls: 'badge-gray' };
  return { label: s, cls: 'badge-gray' };
}

function paymentLabel(s) {
  if (s === '已支付') return { label: '已支付', cls: 'badge-green' };
  if (s === '部分支付') return { label: '部分', cls: 'badge-amber' };
  if (s === '未支付') return { label: '未支付', cls: 'badge-amber' };
  if (s === '已退款' || s === '取消支付') return { label: s, cls: 'badge-gray' };
  return { label: s, cls: 'badge-gray' };
}

function et818BadgeCls(s) {
  if (s === '已提交') return 'badge-green';
  if (s === '已填写') return 'badge-amber';
  if (s === '失败') return 'badge-red';
  return 'badge-gray';
}

function renderGroupEtProgress(items) {
  const done = items.filter(o => o.et818_status === '已提交' || o.et818_status === '已填写').length;
  const total = items.length;
  const pct = total > 0 ? Math.round(done / total * 100) : 0;
  const isDone = done === total && total > 0;
  return `<span>ET ${done}/${total}</span><span class="et-bar-bg"><span class="et-bar-fill${isDone ? ' done' : ''}" style="width:${pct}%"></span></span>`;
}

function channelBadgeCls(s) {
  if (s === '携程') return 'badge-blue';
  if (s === '抖音') return 'badge-pink';
  if (s === '微信') return 'badge-green';
  if (s === '小红书') return 'badge-red';
  return 'badge-gray';
}

function fmtMoney(v) {
  if (v === null || v === undefined) return '—';
  return '¥' + Number(v).toLocaleString('zh-CN', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}

function esc(s) {
  return String(s ?? '').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}

// Simple string hash for consistent color assignment
function hashStr(s) {
  let h = 0;
  for (let i = 0; i < s.length; i++) {
    h = ((h << 5) - h) + s.charCodeAt(i);
    h |= 0;
  }
  return Math.abs(h);
}

function toggleAll(cb, date) {
  document.querySelectorAll(`.group:has(.gh .date:contains("${date}")) .row-cb`).forEach(c => c.checked = cb.checked);
}

// Note inline edit (placeholder)
function editNote(el, orderId) {
  const current = (el.textContent === '添加备注' || el.textContent === '备注') ? '' : el.textContent;
  const input = document.createElement('input');
  input.className = 'note-input';
  input.value = current;
  input.placeholder = '输入备注...';
  input.addEventListener('blur', () => {
    // TODO: save to API
    el.parentNode.replaceChild(el, input);
    if (input.value.trim()) {
      el.textContent = input.value.trim();
      el.className = 'editable-note';
    } else {
      el.textContent = '添加备注';
      el.className = 'editable-note empty';
    }
  });
  input.addEventListener('keydown', e => {
    if (e.key === 'Enter') input.blur();
    if (e.key === 'Escape') { input.value = current; input.blur(); }
  });
  el.parentNode.replaceChild(input, el);
  input.focus();
  input.select();
}

// Owner / butler inline edit
function editField(el, orderId, field) {
  const current = el.querySelector('.placeholder') ? '' : el.textContent.trim();
  const input = document.createElement('input');
  input.className = 'note-input';
  input.style.width = '60px';
  input.value = current;
  input.placeholder = field === 'owner' ? '负责人' : '管家';
  input.addEventListener('blur', () => {
    const order = MOCK_ORDERS.find(o => o.id === orderId);
    if (order) order[field] = input.value.trim();
    const val = input.value.trim();
    el.innerHTML = val ? esc(val) : '<span class="placeholder">—</span>';
  });
  input.addEventListener('keydown', e => {
    if (e.key === 'Enter') input.blur();
    if (e.key === 'Escape') { input.value = current; input.blur(); }
  });
  el.innerHTML = '';
  el.appendChild(input);
  input.focus();
  input.select();
}

// Polyfill for :contains (used by toggleAll)
document.querySelectorAll = (function(orig) {
  return function(sel) {
    if (sel.includes(':contains(')) {
      const parts = sel.split(/(:contains\([^)]+\))/g);
      let base = parts[0];
      for (let i = 1; i < parts.length; i += 2) {
        const cond = parts[i];
        const text = cond.match(/:contains\("([^"]+)"\)/)?.[1];
        if (text) {
          const els = orig.call(this, base);
          const filtered = [];
          els.forEach(el => {
            if (el.textContent.includes(text)) filtered.push(el);
          });
          return filtered;
        }
        if (parts[i+1]) base += parts[i+1];
      }
    }
    return orig.call(this, sel);
  };
})(document.querySelectorAll.bind(document));
</script>
</body>
</html>
